def main() -> None:
    log("Starting AWDB Colorado WTEQ workflow...")

    # Load local iMAP files if present
    imap_peak_df = load_imap_peak_csv(IMAP_PEAK_FILE)
    imap_melt_df = load_imap_melt_csv(IMAP_MELT_FILE)

    if not imap_peak_df.empty:
        log(f"Loaded peak iMAP file: {IMAP_PEAK_FILE.name} ({len(imap_peak_df)} rows)")
    if not imap_melt_df.empty:
        log(f"Loaded melt iMAP file: {IMAP_MELT_FILE.name} ({len(imap_melt_df)} rows)")

    # Historical comparison
    comparison_results = run_comparison_years(
        years=COMPARISON_YEARS,
        begin_mm_dd=COMPARISON_BEGIN_MM_DD,
        end_mm_dd=COMPARISON_END_MM_DD,
        chunk_size=CHUNK_SIZE,
    )

    stations_df = comparison_results["stations"]
    daily_df_all_years = comparison_results["daily_long"]
    summary_df_all_years = comparison_results["summary"]
    statewide_df_all_years = comparison_results["statewide"]
    metrics_df_all_years = comparison_results["metrics"]

    write_csv(stations_df, "co_stations_metadata.csv")
    write_csv(daily_df_all_years, "co_wteq_daily_long_selected_years.csv")
    write_csv(summary_df_all_years, "co_wteq_station_summary_selected_years.csv")
    write_csv(statewide_df_all_years, "co_wteq_statewide_selected_years.csv")
    write_csv(metrics_df_all_years, "co_wteq_year_metrics_all_available_sites.csv")

    print("\n=== All-available-site comparison metrics ===")
    print(metrics_df_all_years.to_string(index=False))

    # Common-station subset
    common_summary_df = get_common_station_subset(summary_df_all_years, COMPARISON_YEARS)
    common_metrics_df = build_common_station_metrics(common_summary_df)

    write_csv(common_summary_df, "co_wteq_station_summary_common_sites.csv")
    write_csv(common_metrics_df, "co_wteq_year_metrics_common_sites.csv")

    if not common_metrics_df.empty:
        print("\n=== Common-station comparison metrics ===")
        print(common_metrics_df.to_string(index=False))

    # 2026 snapshots
    snapshot_summary_rows: List[pd.DataFrame] = []

    for snapshot_end_date in SNAPSHOT_END_DATES_2026:
        snapshot_tag = sanitize_date_tag(snapshot_end_date)

        snapshot_results = run_2026_snapshot(
            stations_df=stations_df,
            snapshot_end_date=snapshot_end_date,
            snapshot_begin_date=SNAPSHOT_BEGIN_DATE_2026,
            near_meltout_threshold=NEAR_MELTOUT_THRESHOLD,
            effective_meltout_threshold=EFFECTIVE_MELTOUT_THRESHOLD,
            imap_peak_df=imap_peak_df,
            imap_melt_df=imap_melt_df,
        )

        snapshot_daily_long = snapshot_results["daily_long"]
        snapshot_station_diag = snapshot_results["station_diagnostics"]
        snapshot_daily_diag = snapshot_results["daily_diagnostics"]
        snapshot_top_days = snapshot_results["top_statewide_melt_days"]
        snapshot_top_events = snapshot_results["top_station_melt_events"]
        snapshot_writeup_summary = snapshot_results["writeup_summary"]

        if not snapshot_writeup_summary.empty:
            snapshot_writeup_summary.insert(0, "snapshot_end_date", pd.to_datetime(snapshot_end_date))
            snapshot_summary_rows.append(snapshot_writeup_summary)

        write_csv(snapshot_daily_long, f"co_2026_daily_long_{snapshot_tag}.csv")
        write_csv(snapshot_station_diag, f"co_2026_station_diagnostics_{snapshot_tag}.csv")
        write_csv(snapshot_daily_diag, f"co_2026_daily_diagnostics_{snapshot_tag}.csv")
        write_csv(snapshot_top_days.head(25), f"co_2026_top_25_statewide_melt_days_{snapshot_tag}.csv")
        write_csv(snapshot_top_events.head(100), f"co_2026_top_100_station_melt_events_{snapshot_tag}.csv")
        write_csv(snapshot_writeup_summary, f"co_2026_writeup_summary_{snapshot_tag}.csv")

        print(f"\n=== 2026 full-network snapshot through {snapshot_end_date} ===")
        if not snapshot_writeup_summary.empty:
            row = snapshot_writeup_summary.iloc[0]
            print(f"Sites in snapshot: {int(row['n_sites'])}")
            print(f"Sites peaked by end date: {int(row['n_peaked_by_end_date'])}")
            print(f"Strict zero sites: {int(row['n_strict_zero'])}")
            print(f"Effective melt-out sites (<= {EFFECTIVE_MELTOUT_THRESHOLD}\"): {int(row['n_effective_meltout'])}")
            print(f"Near melt-out sites (<= {NEAR_MELTOUT_THRESHOLD}\"): {int(row['n_near_meltout'])}")
            print(f"Median current SWE: {row['median_current_swe']:.2f}")
            print(f"Median % loss from peak: {row['median_pct_loss']:.3f}")
            print(f"Median melt rate: {row['median_melt_rate_in_per_day']:.3f} in/day")
            if pd.notna(row["median_peak_timing_anomaly_days"]):
                print(f"Median peak timing anomaly: {row['median_peak_timing_anomaly_days']:.1f} days")
            print(f"March mean % of sites declining: {row['march_mean_pct_declining']:.3%}")
            print(
                f"Worst statewide decline day: {pd.to_datetime(row['worst_decline_day']).date()} | "
                f"total_daily_change={row['worst_decline_total_daily_change']:.2f} | "
                f"median_daily_change={row['worst_decline_median_daily_change']:.3f} | "
                f"pct_declining={row['worst_decline_pct_declining']:.3%}"
            )

    if snapshot_summary_rows:
        combined_snapshot_summary = pd.concat(snapshot_summary_rows, ignore_index=True)
        write_csv(combined_snapshot_summary, "co_2026_writeup_summary_all_snapshots.csv")

    print("\n=== Quick diagnostics ===")
    print(f"Colorado stations loaded: {len(stations_df)}")
    print(f"Comparison years: {COMPARISON_YEARS}")
    print(f"2026 snapshot end dates: {SNAPSHOT_END_DATES_2026}")
    print(f"Using iMAP peak file: {IMAP_PEAK_FILE.exists()}")
    print(f"Using iMAP melt file: {IMAP_MELT_FILE.exists()}")
    print(f"Output folder: {OUTPUT_DIR.resolve()}")

    log("\nDone.")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nInterrupted by user.", file=sys.stderr)
        sys.exit(1)
    except Exception as exc:
        print(f"\nERROR: {exc}", file=sys.stderr)
        sys.exit(1)
