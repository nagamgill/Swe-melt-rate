def normalize_columns(df: pd.DataFrame) -> pd.DataFrame:
    df = df.copy()
    df.columns = [str(c).strip().lower().replace(" ", "_") for c in df.columns]
    return df


def load_imap_peak_csv(path: Path) -> pd.DataFrame:
    """
    Peak file usefulness:
    - ID
    - Value_null = this year's peak date
    - POR_Median_Departure_null = departure from POR median peak date
    - Percentile_POR
    - Records_POR
    - POR_Median_null = POR median peak date
    - NRCS_1991_2020_Median_null = 1991-2020 median peak date
    """
    if not path.exists():
        return pd.DataFrame()

    df = pd.read_csv(path)
    df = normalize_columns(df)

    df["station_id_clean"] = pd.to_numeric(df["id"], errors="coerce").astype("Int64")

    out = pd.DataFrame({
        "station_id_clean": df["station_id_clean"],
        "imap_peak_name": df.get("name"),
        "imap_peak_network": df.get("network"),
        "imap_peak_county": df.get("county"),
        "imap_peak_date_raw": df.get("value_null"),
        "imap_peak_por_median_date_raw": df.get("por_median_null"),
        "imap_peak_nrcs_median_date_raw": df.get("nrcs_1991_2020_median_null"),
        "imap_peak_por_departure_days": df.get("por_median_departure_null").apply(parse_departure_days) if "por_median_departure_null" in df.columns else None,
        "imap_peak_percentile_por": pd.to_numeric(df.get("percentile_por"), errors="coerce"),
        "imap_peak_records_por": df.get("records_por"),
        "imap_peak_num_obs_por": pd.to_numeric(df.get("number_of_observations_por"), errors="coerce"),
        "imap_peak_report_created": df.get("date_report_created"),
    })

    # Parse dates into 2026 timestamps where possible
    out["imap_peak_date_2026"] = out["imap_peak_date_raw"].apply(lambda x: parse_mmdd_to_timestamp(x, 2026))
    out["imap_peak_por_median_date_2026"] = out["imap_peak_por_median_date_raw"].apply(lambda x: parse_mmdd_to_timestamp(x, 2026))
    out["imap_peak_nrcs_median_date_2026"] = out["imap_peak_nrcs_median_date_raw"].apply(lambda x: parse_mmdd_to_timestamp(x, 2026))

    return out


def load_imap_melt_csv(path: Path) -> pd.DataFrame:
    """
    Melt file usefulness:
    - ID
    - Value_null = melt-out date this year when present
    - POR_Median_Departure_null = departure from POR median melt-out date
    - Percentile_POR
    - Records_POR
    - POR_Median_null = POR median melt-out date
    - NRCS_1991_2020_Median_null = 1991-2020 median melt-out date
    """
    if not path.exists():
        return pd.DataFrame()

    df = pd.read_csv(path)
    df = normalize_columns(df)

    df["station_id_clean"] = pd.to_numeric(df["id"], errors="coerce").astype("Int64")

    out = pd.DataFrame({
        "station_id_clean": df["station_id_clean"],
        "imap_melt_name": df.get("name"),
        "imap_melt_network": df.get("network"),
        "imap_melt_county": df.get("county"),
        "imap_melt_date_raw": df.get("value_null"),
        "imap_melt_por_median_date_raw": df.get("por_median_null"),
        "imap_melt_nrcs_median_date_raw": df.get("nrcs_1991_2020_median_null"),
        "imap_melt_por_departure_days": df.get("por_median_departure_null").apply(parse_departure_days) if "por_median_departure_null" in df.columns else None,
        "imap_melt_percentile_por": pd.to_numeric(df.get("percentile_por"), errors="coerce"),
        "imap_melt_records_por": df.get("records_por"),
        "imap_melt_num_obs_por": pd.to_numeric(df.get("number_of_observations_por"), errors="coerce"),
        "imap_melt_report_created": df.get("date_report_created"),
    })

    out["imap_melt_date_2026"] = out["imap_melt_date_raw"].apply(lambda x: parse_mmdd_to_timestamp(x, 2026))
    out["imap_melt_por_median_date_2026"] = out["imap_melt_por_median_date_raw"].apply(lambda x: parse_mmdd_to_timestamp(x, 2026))
    out["imap_melt_nrcs_median_date_2026"] = out["imap_melt_nrcs_median_date_raw"].apply(lambda x: parse_mmdd_to_timestamp(x, 2026))

    return out


