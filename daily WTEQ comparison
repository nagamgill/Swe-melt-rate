def get_co_snotel_stations() -> pd.DataFrame:
    url = f"{BASE_URL}/services/v1/stations"
    params = {
        "stationTriplets": "*:CO:SNTL,*:CO:SNTLT",
        "elements": "WTEQ",
        "durations": "DAILY",
        "returnStationElements": "false",
        "activeOnly": "true",
    }

    payload = request_json(url, params, timeout=120)

    rows: List[Dict[str, Any]] = []
    for s in payload:
        rows.append(
            {
                "stationTriplet": s.get("stationTriplet"),
                "stationId": s.get("stationId"),
                "stateCode": s.get("stateCode"),
                "networkCode": s.get("networkCode"),
                "name": s.get("name"),
                "dcoCode": s.get("dcoCode"),
                "countyName": s.get("countyName"),
                "huc": s.get("huc"),
                "elevation_ft": s.get("elevation"),
                "latitude": s.get("latitude"),
                "longitude": s.get("longitude"),
                "dataTimeZone": s.get("dataTimeZone"),
                "operator": s.get("operator"),
                "stationBeginDate": s.get("beginDate"),
                "stationEndDate": s.get("endDate"),
            }
        )

    df = pd.DataFrame(rows)
    if df.empty:
        return df

    df = df.dropna(subset=["stationTriplet"]).sort_values(["name", "stationTriplet"]).reset_index(drop=True)
    df = add_station_id_clean(df)
    return df


# ============================================================
# AWDB daily pull
# ============================================================

def get_daily_wteq(
    station_triplets: List[str],
    begin_date: str,
    end_date: str,
    chunk_size: int = CHUNK_SIZE,
    return_suspect_data: bool = RETURN_SUSPECT_DATA,
) -> pd.DataFrame:
    url = f"{BASE_URL}/services/v1/data"
    all_rows: List[Dict[str, Any]] = []

    triplet_chunks = chunk_list(station_triplets, chunk_size)
    total_chunks = len(triplet_chunks)

    for i, chunk in enumerate(triplet_chunks, start=1):
        log(f"  Pulling chunk {i}/{total_chunks} for {begin_date} to {end_date} ...")

        params = {
            "stationTriplets": ",".join(chunk),
            "elements": "WTEQ",
            "duration": "DAILY",
            "beginDate": begin_date,
            "endDate": end_date,
            "periodRef": "END",
            "centralTendencyType": "ALL",
            "returnFlags": "false",
            "returnOriginalValues": "false",
            "returnSuspectData": str(return_suspect_data).lower(),
        }

        payload = request_json(url, params, timeout=180)

        for station in payload:
            station_triplet = station.get("stationTriplet")

            for block in station.get("data", []):
                station_element = block.get("stationElement", {})
                values = block.get("values", [])

                timing = block.get("timingCentralTendencies", {}) or {}
                median_peak = timing.get("medianPeak", {}) or {}
                average_peak = timing.get("averagePeak", {}) or {}

                median_peak_month = median_peak.get("month")
                median_peak_day = median_peak.get("day")
                median_peak_value = median_peak.get("value")

                average_peak_month = average_peak.get("month")
                average_peak_day = average_peak.get("day")
                average_peak_value = average_peak.get("value")

                for v in values:
                    all_rows.append(
                        {
                            "stationTriplet": station_triplet,
                            "date": v.get("date"),
                            "value": v.get("value"),

                            "elementCode": station_element.get("elementCode"),
                            "durationName": station_element.get("durationName"),
                            "dataPrecision": station_element.get("dataPrecision"),
                            "storedUnitCode": station_element.get("storedUnitCode"),
                            "originalUnitCode": station_element.get("originalUnitCode"),
                            "elementBeginDate": station_element.get("beginDate"),
                            "elementEndDate": station_element.get("endDate"),
                            "derivedData": station_element.get("derivedData"),

                            "qcFlag": v.get("qcFlag"),
                            "qaFlag": v.get("qaFlag"),
                            "origValue": v.get("origValue"),
                            "origQcFlag": v.get("origQcFlag"),
                            "average": v.get("average"),
                            "median": v.get("median"),

                            "median_peak_month": median_peak_month,
                            "median_peak_day": median_peak_day,
                            "median_peak_swe_climo": median_peak_value,
                            "average_peak_month": average_peak_month,
                            "average_peak_day": average_peak_day,
                            "average_peak_swe_climo": average_peak_value,
                        }
                    )

    df = pd.DataFrame(all_rows)
    if df.empty:
        return df

    df["date"] = pd.to_datetime(df["date"], errors="coerce")
    df["value"] = pd.to_numeric(df["value"], errors="coerce")
    df["average"] = pd.to_numeric(df["average"], errors="coerce")
    df["median"] = pd.to_numeric(df["median"], errors="coerce")
    df["median_peak_swe_climo"] = pd.to_numeric(df["median_peak_swe_climo"], errors="coerce")
    df["average_peak_swe_climo"] = pd.to_numeric(df["average_peak_swe_climo"], errors="coerce")

    df = add_station_id_clean(df)
    return df.sort_values(["stationTriplet", "date"]).reset_index(drop=True)


# ============================================================
# Summaries
# ============================================================

def summarize_current_season(
    wteq_df: pd.DataFrame,
    stations_df: pd.DataFrame,
) -> pd.DataFrame:
    if wteq_df.empty:
        return pd.DataFrame()

    summaries: List[Dict[str, Any]] = []

    for station_triplet, g in wteq_df.groupby("stationTriplet"):
        g = g.dropna(subset=["value"]).sort_values("date").copy()
        if g.empty:
            continue

        peak_idx = g["value"].idxmax()
        peak_row = g.loc[peak_idx]
        current_row = g.iloc[-1]

        peak_swe = float(peak_row["value"])
        peak_date = pd.to_datetime(peak_row["date"])
        current_swe = float(current_row["value"])
        current_date = pd.to_datetime(current_row["date"])

        net_loss = peak_swe - current_swe
        pct_loss = net_loss / peak_swe if peak_swe > 0 else None
        days_since_peak = int((current_date - peak_date).days)
        melt_rate = net_loss / days_since_peak if days_since_peak > 0 else None

        climo_row = g[
            g["median_peak_month"].notna() &
            g["median_peak_day"].notna()
        ].head(1)

        if not climo_row.empty:
            median_peak_month = climo_row["median_peak_month"].iloc[0]
            median_peak_day = climo_row["median_peak_day"].iloc[0]
            median_peak_swe_climo = climo_row["median_peak_swe_climo"].iloc[0]

            average_peak_month = climo_row["average_peak_month"].iloc[0]
            average_peak_day = climo_row["average_peak_day"].iloc[0]
            average_peak_swe_climo = climo_row["average_peak_swe_climo"].iloc[0]
        else:
            median_peak_month = None
            median_peak_day = None
            median_peak_swe_climo = None
            average_peak_month = None
            average_peak_day = None
            average_peak_swe_climo = None

        median_peak_date_climo = build_climo_peak_date(
            peak_date.year, median_peak_month, median_peak_day
        )
        average_peak_date_climo = build_climo_peak_date(
            peak_date.year, average_peak_month, average_peak_day
        )

        peak_timing_anomaly_days = (
            int((peak_date - median_peak_date_climo).days)
            if pd.notna(median_peak_date_climo) else None
        )
        average_peak_timing_anomaly_days = (
            int((peak_date - average_peak_date_climo).days)
            if pd.notna(average_peak_date_climo) else None
        )

        peak_swe_departure = (
            peak_swe - float(median_peak_swe_climo)
            if pd.notna(median_peak_swe_climo) else None
        )
        peak_swe_pct_of_climo = (
            peak_swe / float(median_peak_swe_climo)
            if pd.notna(median_peak_swe_climo) and float(median_peak_swe_climo) != 0 else None
        )

        summaries.append(
            {
                "stationTriplet": station_triplet,
                "station_id_clean": g["station_id_clean"].iloc[0],
                "peak_swe": peak_swe,
                "peak_date": peak_date,
                "current_swe": current_swe,
                "current_date": current_date,
                "net_loss": net_loss,
                "pct_loss": pct_loss,
                "days_since_peak": days_since_peak,
                "melt_rate_in_per_day": melt_rate,

                "median_peak_date_climo": median_peak_date_climo,
                "average_peak_date_climo": average_peak_date_climo,
                "median_peak_swe_climo": median_peak_swe_climo,
                "average_peak_swe_climo": average_peak_swe_climo,
                "peak_timing_anomaly_days": peak_timing_anomaly_days,
                "average_peak_timing_anomaly_days": average_peak_timing_anomaly_days,
                "peak_swe_departure": peak_swe_departure,
                "peak_swe_pct_of_climo": peak_swe_pct_of_climo,
            }
        )

    summary_df = pd.DataFrame(summaries)
    if summary_df.empty:
        return summary_df

    out = summary_df.merge(
        stations_df[
            [
                "stationTriplet",
                "station_id_clean",
                "name",
                "networkCode",
                "elevation_ft",
                "latitude",
                "longitude",
                "countyName",
                "huc",
            ]
        ],
        on=["stationTriplet", "station_id_clean"],
        how="left",
    )

    return out.sort_values(["melt_rate_in_per_day", "pct_loss"], ascending=[False, False]).reset_index(drop=True)


def statewide_daily_series(wteq_df: pd.DataFrame) -> pd.DataFrame:
    if wteq_df.empty:
        return pd.DataFrame()

    daily = (
        wteq_df.groupby("date")["value"]
        .agg(
            mean_swe="mean",
            median_swe="median",
            zero_sites=lambda x: int((pd.to_numeric(x, errors="coerce") == 0).sum()),
            total_sites="count",
        )
        .reset_index()
    )

    nonzero = (
        wteq_df.groupby("date")["value"]
        .apply(safe_mean_nonzero)
        .reset_index(name="mean_nonzero_swe")
    )

    daily = daily.merge(nonzero, on="date", how="left")
    daily = daily.sort_values("date").reset_index(drop=True)
    daily["daily_change_mean_swe"] = daily["mean_swe"].diff()
    daily["daily_change_mean_nonzero_swe"] = daily["mean_nonzero_swe"].diff()
    return daily


# ============================================================
# 2026 snapshot diagnostics
# ============================================================

def build_snapshot_station_diagnostics(
    wteq_df: pd.DataFrame,
    stations_df: pd.DataFrame,
    near_meltout_threshold: float = NEAR_MELTOUT_THRESHOLD,
    effective_meltout_threshold: float = EFFECTIVE_MELTOUT_THRESHOLD,
) -> pd.DataFrame:
    station_diag = summarize_current_season(wteq_df, stations_df).copy()
    if station_diag.empty:
        return station_diag

    station_diag["peaked_by_end_date"] = station_diag["peak_date"] < station_diag["current_date"]
    station_diag["strict_zero"] = station_diag["current_swe"] == 0
    station_diag["effective_meltout"] = station_diag["current_swe"] <= effective_meltout_threshold
    station_diag["near_meltout"] = station_diag["current_swe"] <= near_meltout_threshold
    station_diag["peaked_7plus_days_early"] = station_diag["peak_timing_anomaly_days"] <= -7
    station_diag["peaked_14plus_days_early"] = station_diag["peak_timing_anomaly_days"] <= -14
    return station_diag


def build_snapshot_daily_diagnostics(
    wteq_df: pd.DataFrame,
    near_meltout_threshold: float = NEAR_MELTOUT_THRESHOLD,
    effective_meltout_threshold: float = EFFECTIVE_MELTOUT_THRESHOLD,
) -> pd.DataFrame:
    if wteq_df.empty:
        return pd.DataFrame()

    df = wteq_df.copy().sort_values(["stationTriplet", "date"]).reset_index(drop=True)
    df["daily_change"] = df.groupby("stationTriplet")["value"].diff()

    daily_rows: List[Dict[str, Any]] = []

    for date, g in df.groupby("date"):
        vals = pd.to_numeric(g["value"], errors="coerce")
        changes = pd.to_numeric(g["daily_change"], errors="coerce")

        valid_changes = changes.dropna()
        decline_changes = valid_changes[valid_changes < 0]

        n_sites = int(vals.notna().sum())
        n_declining = int((valid_changes < 0).sum())
        n_flat = int((valid_changes == 0).sum())
        n_gaining = int((valid_changes > 0).sum())

        n_strict_zero = int((vals == 0).sum())
        n_effective_meltout = int((vals <= effective_meltout_threshold).sum())
        n_near_meltout = int((vals <= near_meltout_threshold).sum())

        daily_rows.append(
            {
                "date": pd.to_datetime(date),
                "n_sites": n_sites,
                "n_declining": n_declining,
                "pct_declining": n_declining / n_sites if n_sites > 0 else None,
                "n_flat": n_flat,
                "n_gaining": n_gaining,
                "n_strict_zero": n_strict_zero,
                "pct_strict_zero": n_strict_zero / n_sites if n_sites > 0 else None,
                "n_effective_meltout": n_effective_meltout,
                "pct_effective_meltout": n_effective_meltout / n_sites if n_sites > 0 else None,
                "n_near_meltout": n_near_meltout,
                "pct_near_meltout": n_near_meltout / n_sites if n_sites > 0 else None,
                "median_daily_change": valid_changes.median() if not valid_changes.empty else None,
                "mean_daily_change": valid_changes.mean() if not valid_changes.empty else None,
                "median_daily_decline": decline_changes.median() if not decline_changes.empty else None,
                "mean_daily_decline": decline_changes.mean() if not decline_changes.empty else None,
                "total_daily_change": valid_changes.sum() if not valid_changes.empty else None,
            }
        )

    return pd.DataFrame(daily_rows).sort_values("date").reset_index(drop=True)


def summarize_snapshot_for_writeup(
    station_diag: pd.DataFrame,
    daily_diag: pd.DataFrame,
) -> pd.DataFrame:
    if station_diag.empty or daily_diag.empty:
        return pd.DataFrame()

    top_day = daily_diag.sort_values(["total_daily_change", "median_daily_change"], ascending=[True, True]).iloc[0]

    march_slice = daily_diag[
        (daily_diag["date"] >= pd.Timestamp("2026-03-01")) &
        (daily_diag["date"] <= pd.Timestamp("2026-03-31"))
    ].copy()

    return pd.DataFrame(
        [
            {
                "n_sites": len(station_diag),
                "n_peaked_by_end_date": int(station_diag["peaked_by_end_date"].sum()),
                "n_strict_zero": int(station_diag["strict_zero"].sum()),
                "n_effective_meltout": int(station_diag["effective_meltout"].sum()),
                "n_near_meltout": int(station_diag["near_meltout"].sum()),
                "median_peak_swe": float(station_diag["peak_swe"].median()),
                "median_current_swe": float(station_diag["current_swe"].median()),
                "median_net_loss": float(station_diag["net_loss"].median()),
                "median_pct_loss": float(station_diag["pct_loss"].median()),
                "median_melt_rate_in_per_day": float(station_diag["melt_rate_in_per_day"].median()),
                "mean_melt_rate_in_per_day": float(station_diag["melt_rate_in_per_day"].mean()),
                "median_peak_timing_anomaly_days": float(station_diag["peak_timing_anomaly_days"].dropna().median())
                if station_diag["peak_timing_anomaly_days"].notna().any() else None,
                "pct_peaked_7plus_days_early": float(station_diag["peaked_7plus_days_early"].mean())
                if "peaked_7plus_days_early" in station_diag else None,
                "pct_peaked_14plus_days_early": float(station_diag["peaked_14plus_days_early"].mean())
                if "peaked_14plus_days_early" in station_diag else None,
                "march_mean_pct_declining": float(march_slice["pct_declining"].mean()) if not march_slice.empty else None,
                "march_median_daily_change": float(march_slice["median_daily_change"].median()) if not march_slice.empty else None,
                "worst_decline_day": pd.to_datetime(top_day["date"]),
                "worst_decline_total_daily_change": float(top_day["total_daily_change"]),
                "worst_decline_median_daily_change": float(top_day["median_daily_change"]),
                "worst_decline_pct_declining": float(top_day["pct_declining"]),
            }
        ]
    )


def run_2026_snapshot(
    stations_df: pd.DataFrame,
    snapshot_end_date: str,
    snapshot_begin_date: str = SNAPSHOT_BEGIN_DATE_2026,
    near_meltout_threshold: float = NEAR_MELTOUT_THRESHOLD,
    effective_meltout_threshold: float = EFFECTIVE_MELTOUT_THRESHOLD,
    imap_peak_df: Optional[pd.DataFrame] = None,
    imap_melt_df: Optional[pd.DataFrame] = None,
) -> Dict[str, pd.DataFrame]:
    log(f"\nRunning 2026 full-network snapshot through {snapshot_end_date}")

    daily_df = get_daily_wteq(
        station_triplets=stations_df["stationTriplet"].tolist(),
        begin_date=snapshot_begin_date,
        end_date=snapshot_end_date,
        chunk_size=CHUNK_SIZE,
    )

    station_diag = build_snapshot_station_diagnostics(
        daily_df,
        stations_df,
        near_meltout_threshold=near_meltout_threshold,
        effective_meltout_threshold=effective_meltout_threshold,
    )

    # Merge current iMAP reference files if present
    if imap_peak_df is not None and not imap_peak_df.empty:
        station_diag = station_diag.merge(imap_peak_df, on="station_id_clean", how="left")

    if imap_melt_df is not None and not imap_melt_df.empty:
        station_diag = station_diag.merge(imap_melt_df, on="station_id_clean", how="left")

    daily_diag = build_snapshot_daily_diagnostics(
        daily_df,
        near_meltout_threshold=near_meltout_threshold,
        effective_meltout_threshold=effective_meltout_threshold,
    )

    top_statewide_melt_days = daily_diag.sort_values(
        ["total_daily_change", "median_daily_change"],
        ascending=[True, True],
    ).reset_index(drop=True)

    event_df = daily_df.copy().sort_values(["stationTriplet", "date"]).reset_index(drop=True)
    event_df["daily_change"] = event_df.groupby("stationTriplet")["value"].diff()
    event_df = event_df[event_df["daily_change"] < 0].copy()
    event_df = event_df.merge(
        stations_df[["stationTriplet", "station_id_clean", "name", "elevation_ft", "latitude", "longitude"]],
        on=["stationTriplet", "station_id_clean"],
        how="left",
    )
    top_station_melt_events = event_df.sort_values("daily_change", ascending=True).reset_index(drop=True)

    writeup_summary = summarize_snapshot_for_writeup(station_diag, daily_diag)

    return {
        "daily_long": daily_df,
        "station_diagnostics": station_diag,
        "daily_diagnostics": daily_diag,
        "top_statewide_melt_days": top_statewide_melt_days,
        "top_station_melt_events": top_station_melt_events,
        "writeup_summary": writeup_summary,
    }


