"""
Colorado SNOTEL WTEQ melt analysis using USDA NRCS AWDB REST API
with automatic integration of current iMAP peak and melt-out CSV exports.

Required local files (same folder as this script)
-------------------------------------------------
- Swe water year peak.csv
- Swe melt out.csv

What this script does
---------------------
1. Pulls Colorado AWDB daily WTEQ for selected comparison years.
2. Preserves historical comparison metrics.
3. Runs 2026 full-network snapshot diagnostics for selected end dates.
4. Merges current iMAP peak and melt-out reference data by station ID.
5. Writes clean CSV outputs for:
   - statewide melt timing and magnitude
   - station-level depletion
   - strongest statewide decline days
   - strongest station-level decline events
   - compact write-up summary tables

Interpretation
--------------
- AWDB daily SWE = actual seasonal behavior, melt rates, daily declines
- iMAP peak/melt files = reference timing, departures, percentiles, records
"""

from __future__ import annotations

import sys
import time
from pathlib import Path
from typing import Any, Dict, List, Optional

import pandas as pd
import requests


# ============================================================
# User settings
# ============================================================

BASE_URL = "https://wcc.sc.egov.usda.gov/awdbRestApi"

SCRIPT_DIR = Path(__file__).resolve().parent
OUTPUT_DIR = SCRIPT_DIR / "awdb_outputs"
OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

# Historical comparison years
COMPARISON_YEARS = [1981, 2002, 2012, 2015, 2017, 2018, 2026]

# Comparison window for all years
COMPARISON_BEGIN_MM_DD = "02-01"
COMPARISON_END_MM_DD = "03-30"   # clean pre-storm baseline

# 2026 snapshot dates to run
SNAPSHOT_BEGIN_DATE_2026 = "2026-02-01"
SNAPSHOT_END_DATES_2026 = [
    "2026-03-30",
    "2026-04-01",
]

# Thresholds for current site status
NEAR_MELTOUT_THRESHOLD = 5.0
EFFECTIVE_MELTOUT_THRESHOLD = 0.5

# API settings
CHUNK_SIZE = 20
MAX_RETRIES = 3
RETRY_SLEEP_SECONDS = 2.0
RETURN_SUSPECT_DATA = False
VERBOSE = True

# Local iMAP files
IMAP_PEAK_FILE = SCRIPT_DIR / "Swe water year peak.csv"
IMAP_MELT_FILE = SCRIPT_DIR / "Swe melt out.csv"


# ============================================================
# Utility helpers
# ============================================================

def log(msg: str) -> None:
    if VERBOSE:
        print(msg)


def chunk_list(items: List[str], chunk_size: int) -> List[List[str]]:
    return [items[i:i + chunk_size] for i in range(0, len(items), chunk_size)]


def request_json(
    url: str,
    params: Dict[str, Any],
    timeout: int = 120,
    max_retries: int = MAX_RETRIES,
) -> Any:
    last_err: Optional[Exception] = None

    for attempt in range(1, max_retries + 1):
        try:
            r = requests.get(url, params=params, timeout=timeout)
            r.raise_for_status()
            return r.json()
        except Exception as e:
            last_err = e
            if attempt < max_retries:
                log(f"Request failed (attempt {attempt}/{max_retries}). Retrying in {RETRY_SLEEP_SECONDS}s...")
                time.sleep(RETRY_SLEEP_SECONDS)

    raise RuntimeError(
        f"Request failed after {max_retries} attempts.\nURL: {url}\nParams: {params}\nError: {last_err}"
    )


def safe_mean_nonzero(x: pd.Series) -> Optional[float]:
    nz = x[pd.to_numeric(x, errors="coerce") > 0]
    if nz.empty:
        return None
    return float(pd.to_numeric(nz, errors="coerce").mean())


def write_csv(df: pd.DataFrame, filename: str) -> None:
    path = OUTPUT_DIR / filename
    df.to_csv(path, index=False)
    log(f"Wrote: {path}")


def sanitize_date_tag(date_str: str) -> str:
    return date_str.replace("-", "")


def add_station_id_clean(df: pd.DataFrame) -> pd.DataFrame:
    df = df.copy()
    df["station_id_clean"] = (
        df["stationTriplet"]
        .astype(str)
        .str.split(":")
        .str[0]
        .pipe(pd.to_numeric, errors="coerce")
        .astype("Int64")
    )
    return df


def build_climo_peak_date(year: int, month: Any, day: Any) -> pd.Timestamp:
    if pd.isna(month) or pd.isna(day):
        return pd.NaT
    try:
        return pd.Timestamp(year=int(year), month=int(month), day=int(day))
    except Exception:
        return pd.NaT


def parse_mmdd_to_timestamp(mmdd_value: Any, target_year: int) -> pd.Timestamp:
    """
    Parse strings like '03-14' into a Timestamp in target_year.
    Returns NaT on failure.
    """
    if pd.isna(mmdd_value):
        return pd.NaT
    s = str(mmdd_value).strip()
    if not s or s.lower() == "nan":
        return pd.NaT

    for fmt in ("%m-%d", "%m/%d"):
        try:
            dt = pd.to_datetime(s, format=fmt)
            return pd.Timestamp(year=target_year, month=dt.month, day=dt.day)
        except Exception:
            continue
    return pd.NaT


def parse_departure_days(value: Any) -> Optional[float]:
    """
    Parse strings like '-25 days' into numeric days.
    """
    if pd.isna(value):
        return None
    s = str(value).strip().lower()
    if not s or s == "nan":
        return None
    s = s.replace("days", "").replace("day", "").strip()
    try:
        return float(s)
    except Exception:
        return None


